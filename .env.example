# ============================================================================
# SmartTips - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to git

# ----- Database -----
DATABASE_URL="postgresql://postgres:password@localhost:5432/smarttips"
DIRECT_URL="postgresql://postgres:password@localhost:5432/smarttips"

# ----- Auth -----
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-too-in-production-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# ----- Redis -----
REDIS_URL="redis://localhost:6379"

# ----- ML Service -----
ML_SERVICE_URL="http://localhost:8000"
ML_SERVICE_SHARED_SECRET="change-me-shared-secret-between-api-and-ml"

# ----- Cloudflare R2 -----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_MODELS="smarttips-models"
R2_BUCKET_REPORTS="smarttips-reports"

# ----- Email (Resend) -----
RESEND_API_KEY="re_your_resend_api_key_here"
# Expéditeur des emails d'invitation (domaine Resend vérifié requis en prod)
INVITATION_FROM_EMAIL="SmartTips <onboarding@resend.dev>"
# Durée de validité des invitations en jours (défaut : 7)
INVITATION_TTL_DAYS=7

# ----- Frontend / CORS -----
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# URL UNIQUE pour générer les magic links d'invitation (UNE SEULE URL, pas de virgule)
FRONTEND_URL="http://localhost:3000"
# Origines CORS autorisées (peut contenir plusieurs URLs séparées par virgule)
# CORS_ORIGINS="https://smarttips-ashen.vercel.app,https://smarttips-preview.vercel.app"
CORS_ORIGINS="http://localhost:3000"

# ----- Observability -----
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ----- Stripe (V2) -----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ----- Env -----
NODE_ENV="development"
LOG_LEVEL="debug"
