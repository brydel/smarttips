// ============================================================================
// SmartTips - Prisma Schema
// ============================================================================
// Multi-tenant SaaS for fair tip distribution with online ML learning.
//
// V2 decisions after manager review:
//   - Keep tenant_id directly on child business tables for performance, RLS, and safety.
//   - Name ambiguous User relations explicitly.
//   - Fix audit/compliance contradiction: audit logs are NEVER cascade-deleted.
//   - Use soft delete / status transitions for critical business data.
//   - Keep employee photos, but keep them lean: no FIFA/card/gamified concept.
//   - Avoid a full MediaAsset system in the MVP.
//
// PostgreSQL prerequisites:
//   CREATE EXTENSION IF NOT EXISTS pgcrypto;
//   CREATE EXTENSION IF NOT EXISTS citext;
//
// Conventions:
//   - All IDs are UUIDs generated by gen_random_uuid().
//   - Tables use snake_case via @@map.
//   - Columns use snake_case via @map.
//   - Money uses Decimal(10, 2), never Float.
//   - Timestamps use created_at / updated_at on mutable entities.
//   - Soft delete uses deleted_at on critical entities.
//   - Multi-tenant isolation uses tenant_id on every business table + indexes.
//   - FK relations use explicit onDelete strategies.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "metrics"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  EMPLOYEE

  @@map("user_role")
}

enum EmployeeRole {
  SERVER
  BARTENDER
  BUSSER
  HOST
  COOK
  CHEF

  @@map("employee_role")
}

enum Language {
  FR
  EN

  @@map("language")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE

  @@map("plan")
}

enum ShiftType {
  BREAKFAST
  LUNCH
  DINNER
  LATE_NIGHT

  @@map("shift_type")
}

enum ShiftStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
  CANCELLED

  @@map("shift_status")
}

enum AssignmentStatus {
  ASSIGNED
  CHECKED_IN
  COMPLETED
  NO_SHOW

  @@map("assignment_status")
}

enum PaymentMethod {
  CASH
  CARD
  MIXED

  @@map("payment_method")
}

enum OrderStatus {
  OPEN
  SENT
  PAID
  VOIDED

  @@map("order_status")
}

enum TipPoolStatus {
  DECLARED
  DISTRIBUTED
  FINALIZED
  VOIDED

  @@map("tip_pool_status")
}

enum DistributionMode {
  RULES_ONLY
  ML_ASSISTED
  ML_FULL

  @@map("distribution_mode")
}

enum ComputationMethod {
  RULES
  ML_ASSISTED
  ML_FULL
  MANUAL_OVERRIDE

  @@map("computation_method")
}

enum MLAlgorithm {
  LINEAR_REGRESSION
  HOEFFDING_TREE
  ENSEMBLE

  @@map("ml_algorithm")
}

enum MLModelStatus {
  TRAINING
  ACTIVE
  ARCHIVED
  REJECTED

  @@map("ml_model_status")
}

enum TrainingTrigger {
  AUTO_AFTER_SHIFT
  MANUAL_FEEDBACK
  RETRAIN

  @@map("training_trigger")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  VOID
  RESTORE
  ARCHIVE

  @@map("audit_action")
}

enum ExportFormat {
  CSV
  PDF
  JSON

  @@map("export_format")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED

  @@map("subscription_status")
}

enum UsageMetricType {
  SHIFTS_PER_MONTH
  EMPLOYEES_ACTIVE
  ML_PREDICTIONS

  @@map("usage_metric_type")
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED

  @@map("photo_status")
}

// ============================================================================
// CORE - TENANT & AUTH
// ============================================================================

/// Root entity. A Tenant is a restaurant or franchise location.
/// Business tables reference this via tenant_id for row-level isolation.
/// Do not hard-delete tenants in production. Use deleted_at.
model Tenant {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String    @db.VarChar(255)
  slug             String    @unique @db.VarChar(100)
  email            String    @db.VarChar(255)
  phone            String?   @db.VarChar(50)
  address          Json?
  timezone         String    @default("America/Toronto") @db.VarChar(50)
  currency         String    @default("CAD") @db.Char(3)
  taxRate          Decimal   @default(0.14975) @map("tax_rate") @db.Decimal(5, 4)
  plan             Plan      @default(FREE)
  trialEndsAt      DateTime? @map("trial_ends_at") @db.Timestamptz(6)
  stripeCustomerId String?   @unique @map("stripe_customer_id") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations 1:N
  users              User[]
  refreshTokens      RefreshToken[]
  employees          Employee[]
  employeePhotos     EmployeePhoto[]
  employeeRoleHistory EmployeeRoleHistory[]
  invitations        Invitation[]
  menuCategories     MenuCategory[]
  menuItems          MenuItem[]
  restaurantTables   RestaurantTable[]
  shifts             Shift[]
  shiftAssignments   ShiftAssignment[]
  orders             Order[]
  orderItems         OrderItem[]
  tipPools           TipPool[]
  tipDistributions   TipDistribution[]
  mlModels           MLModel[]
  mlTrainingEvents   MLTrainingEvent[]
  mlPredictions      MLPrediction[]
  fairnessAudits     FairnessAudit[]
  auditLogs          AuditLog[]
  payrollExports     PayrollExport[]
  usageMetrics       UsageMetric[]

  // Relations 1:1
  distributionConfig DistributionConfig?
  subscription       Subscription?

  @@index([slug])
  @@index([plan, deletedAt])
  @@map("tenants")
}

/// User account. Belongs to exactly one tenant.
/// Email is unique per tenant, not globally.
model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  email          String    @db.Citext
  hashedPassword String    @map("hashed_password") @db.VarChar(255)
  role           UserRole
  name           String    @db.VarChar(255)
  phone          String?   @db.VarChar(50)
  language       Language  @default(FR)
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant                     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  refreshTokens              RefreshToken[]
  employee                   Employee?
  uploadedEmployeePhotos      EmployeePhoto[]        @relation("EmployeePhotoUploadedBy")
  approvedEmployeePhotos      EmployeePhoto[]        @relation("EmployeePhotoApprovedBy")
  invitationsSent            Invitation[]           @relation("InvitedBy")
  shiftsCreated              Shift[]                @relation("ShiftCreatedBy")
  shiftsClosed               Shift[]                @relation("ShiftClosedBy")
  tipPoolsDeclared           TipPool[]              @relation("TipPoolDeclaredBy")
  tipDistributionsAdjusted   TipDistribution[]      @relation("TipDistributionAdjustedBy")
  distributionConfigUpdates  DistributionConfig[]   @relation("DistributionConfigUpdatedBy")
  payrollExportsGenerated    PayrollExport[]        @relation("PayrollExportGeneratedBy")
  fairnessAuditsReviewed     FairnessAudit[]        @relation("FairnessAuditReviewedBy")
  employeeRoleHistoryChanges EmployeeRoleHistory[]  @relation("EmployeeRoleHistoryChangedBy")
  auditLogs                  AuditLog[]

  @@unique([tenantId, email], name: "unique_user_email_per_tenant")
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, deletedAt])
  @@map("users")
}

/// Refresh tokens stored hashed.
/// Never store raw refresh tokens.
model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  ipAddress String?   @map("ip_address") @db.Inet
  userAgent String?   @map("user_agent") @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([userId])
  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Invitation to join a tenant.
/// Token is hashed for the same reason as RefreshToken.
model Invitation {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  email      String    @db.Citext
  role       UserRole
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz(6)
  invitedBy  String    @map("invited_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invitee User   @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([tenantId, email])
  @@index([tenantId, invitedBy])
  @@index([tokenHash])
  @@map("invitations")
}

// ============================================================================
// HUMAN RESOURCES
// ============================================================================

/// Employee profile. Not every employee has a User account.
/// Soft delete is used for legal retention.
model Employee {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  userId          String?      @unique @map("user_id") @db.Uuid
  employeeNumber  String?      @map("employee_number") @db.VarChar(50)
  firstName       String       @map("first_name") @db.VarChar(100)
  lastName        String       @map("last_name") @db.VarChar(100)
  email           String?      @db.Citext
  phone           String?      @db.VarChar(50)
  role            EmployeeRole
  hireDate        DateTime     @map("hire_date") @db.Date
  terminationDate DateTime?    @map("termination_date") @db.Date
  hourlyWage      Decimal      @map("hourly_wage") @db.Decimal(10, 2)
  coefficient     Decimal      @default(1.0) @db.Decimal(4, 2)
  notes           String?      @db.Text
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(6)

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user             User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  profilePhoto     EmployeePhoto?
  shiftAssignments ShiftAssignment[]
  roleHistory      EmployeeRoleHistory[]
  ordersAsServer   Order[]               @relation("OrderServer")
  tipDistributions TipDistribution[]
  mlPredictions    MLPrediction[]

  @@unique([tenantId, employeeNumber], name: "unique_employee_number_per_tenant")
  @@index([tenantId])
  @@index([tenantId, role])
  @@index([tenantId, active, deletedAt])
  @@index([userId])
  @@map("employees")
}

/// Lean employee photo table.
/// Keep this simple for MVP: no media platform, no gamification, no card system.
/// Store URLs and metadata only; binary files live in object storage.
model EmployeePhoto {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String      @map("tenant_id") @db.Uuid
  employeeId       String      @unique @map("employee_id") @db.Uuid
  uploadedById     String?     @map("uploaded_by_id") @db.Uuid
  approvedById     String?     @map("approved_by_id") @db.Uuid
  status           PhotoStatus @default(PENDING)

  originalUrl      String      @map("original_url") @db.VarChar(1000)
  displayUrl       String?     @map("display_url") @db.VarChar(1000)
  thumbnailUrl     String?     @map("thumbnail_url") @db.VarChar(1000)
  mimeType         String      @map("mime_type") @db.VarChar(100)
  widthPx          Int?        @map("width_px")
  heightPx         Int?        @map("height_px")
  sizeBytes        BigInt?     @map("size_bytes")
  sha256Hash       String?     @map("sha256_hash") @db.VarChar(64)
  is4kReady        Boolean     @default(false) @map("is_4k_ready")
  altText          String?     @map("alt_text") @db.VarChar(255)

  approvedAt       DateTime?   @map("approved_at") @db.Timestamptz(6)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?   @map("deleted_at") @db.Timestamptz(6)

  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee         Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy       User?       @relation("EmployeePhotoUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  approvedBy       User?       @relation("EmployeePhotoApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, is4kReady])
  @@index([tenantId, deletedAt])
  @@index([uploadedById])
  @@index([approvedById])
  @@map("employee_photos")
}

/// Tracks role changes for HR audit and ML feature history.
model EmployeeRoleHistory {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  employeeId    String       @map("employee_id") @db.Uuid
  previousRole  EmployeeRole @map("previous_role")
  newRole       EmployeeRole @map("new_role")
  changedBy     String       @map("changed_by") @db.Uuid
  reason        String?      @db.Text
  effectiveDate DateTime     @map("effective_date") @db.Date
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changedByUser User     @relation("EmployeeRoleHistoryChangedBy", fields: [changedBy], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([employeeId])
  @@index([employeeId, effectiveDate])
  @@map("employee_role_history")
}

// ============================================================================
// MENU
// ============================================================================

model MenuCategory {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String    @db.VarChar(100)
  displayOrder Int       @default(0) @map("display_order")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  items  MenuItem[]

  @@index([tenantId, displayOrder])
  @@index([tenantId, active, deletedAt])
  @@map("menu_categories")
}

model MenuItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  categoryId  String    @map("category_id") @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  cost        Decimal?  @db.Decimal(10, 2)
  active      Boolean   @default(true)
  imageUrl    String?   @map("image_url") @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, active, deletedAt])
  @@map("menu_items")
}

// ============================================================================
// SHIFTS & SCHEDULING
// ============================================================================

model Shift {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  date          DateTime    @db.Date
  shiftType     ShiftType   @map("shift_type")
  startTime     DateTime    @map("start_time") @db.Timestamptz(6)
  endTime       DateTime    @map("end_time") @db.Timestamptz(6)
  actualEndTime DateTime?   @map("actual_end_time") @db.Timestamptz(6)
  status        ShiftStatus @default(PLANNED)
  notes         String?     @db.Text
  createdBy     String      @map("created_by") @db.Uuid
  closedBy      String?     @map("closed_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?   @map("deleted_at") @db.Timestamptz(6)

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  creator          User              @relation("ShiftCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  closer           User?             @relation("ShiftClosedBy", fields: [closedBy], references: [id], onDelete: SetNull)
  assignments      ShiftAssignment[]
  orders           Order[]
  tipPool          TipPool?
  mlTrainingEvents MLTrainingEvent[]
  mlPredictions    MLPrediction[]

  @@unique([tenantId, date, shiftType], name: "one_shift_per_type_per_day")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@index([tenantId, status, date])
  @@index([tenantId, deletedAt])
  @@map("shifts")
}

model ShiftAssignment {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  shiftId         String           @map("shift_id") @db.Uuid
  employeeId      String           @map("employee_id") @db.Uuid
  roleDuringShift EmployeeRole     @map("role_during_shift")
  scheduledHours  Decimal          @map("scheduled_hours") @db.Decimal(5, 2)
  hoursWorked     Decimal?         @map("hours_worked") @db.Decimal(5, 2)
  breakMinutes    Int              @default(0) @map("break_minutes")
  checkInAt       DateTime?        @map("check_in_at") @db.Timestamptz(6)
  checkOutAt      DateTime?        @map("check_out_at") @db.Timestamptz(6)
  status          AssignmentStatus @default(ASSIGNED)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, shiftId])
  @@index([tenantId, employeeId])
  @@index([tenantId, shiftId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([shiftId])
  @@index([employeeId])
  @@map("shift_assignments")
}

// ============================================================================
// ORDERS & SALES
// ============================================================================

model RestaurantTable {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  tableNumber String    @map("table_number") @db.VarChar(50)
  section     String?   @db.VarChar(100)
  capacity    Int       @default(4)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  orders Order[]

  @@unique([tenantId, tableNumber], name: "unique_table_per_tenant")
  @@index([tenantId, section])
  @@index([tenantId, active, deletedAt])
  @@map("restaurant_tables")
}

model Order {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  shiftId         String         @map("shift_id") @db.Uuid
  tableId         String         @map("table_id") @db.Uuid
  serverId        String         @map("server_id") @db.Uuid
  orderNumber     String         @map("order_number") @db.VarChar(50)
  guestCount      Int            @default(1) @map("guest_count")
  subtotal        Decimal        @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal        @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount     Decimal        @default(0) @map("total_amount") @db.Decimal(10, 2)
  paymentMethod   PaymentMethod? @map("payment_method")
  status          OrderStatus    @default(OPEN)
  openedAt        DateTime       @default(now()) @map("opened_at") @db.Timestamptz(6)
  closedAt        DateTime?      @map("closed_at") @db.Timestamptz(6)
  durationMinutes Int?           @map("duration_minutes")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shift  Shift           @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  table  RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Restrict)
  server Employee        @relation("OrderServer", fields: [serverId], references: [id], onDelete: Restrict)
  items  OrderItem[]

  @@unique([tenantId, orderNumber], name: "unique_order_number_per_tenant")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([shiftId])
  @@index([shiftId, serverId])
  @@index([serverId])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  menuItemId String   @map("menu_item_id") @db.Uuid
  quantity   Int      @default(1)
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal   Decimal  @db.Decimal(10, 2)
  notes      String?  @db.Text
  voided     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, orderId])
  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

// ============================================================================
// TIPS - HEART OF THE SYSTEM
// ============================================================================

model TipPool {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  shiftId     String        @unique @map("shift_id") @db.Uuid
  cashAmount  Decimal       @default(0) @map("cash_amount") @db.Decimal(10, 2)
  cardAmount  Decimal       @default(0) @map("card_amount") @db.Decimal(10, 2)
  totalAmount Decimal       @map("total_amount") @db.Decimal(10, 2)
  declaredAt  DateTime      @default(now()) @map("declared_at") @db.Timestamptz(6)
  declaredBy  String        @map("declared_by") @db.Uuid
  notes       String?       @db.Text
  status      TipPoolStatus @default(DECLARED)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?     @map("deleted_at") @db.Timestamptz(6)

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shift         Shift             @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  declarer      User              @relation("TipPoolDeclaredBy", fields: [declaredBy], references: [id], onDelete: Restrict)
  distributions TipDistribution[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@map("tip_pools")
}

/// Central business entity.
/// Stores how much each employee receives, with explainability and audit context.
model TipDistribution {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String            @map("tenant_id") @db.Uuid
  tipPoolId         String            @map("tip_pool_id") @db.Uuid
  employeeId        String            @map("employee_id") @db.Uuid
  mlModelId         String?           @map("ml_model_id") @db.Uuid
  amount            Decimal           @db.Decimal(10, 2)
  contributionScore Decimal           @map("contribution_score") @db.Decimal(10, 4)
  featuresSnapshot  Json?             @map("features_snapshot")
  explanation       Json
  computationMethod ComputationMethod @map("computation_method")
  originalAmount    Decimal?          @map("original_amount") @db.Decimal(10, 2)
  adjustedBy        String?           @map("adjusted_by") @db.Uuid
  adjustmentReason  String?           @map("adjustment_reason") @db.Text
  acknowledgedAt    DateTime?         @map("acknowledged_at") @db.Timestamptz(6)
  paidAt            DateTime?         @map("paid_at") @db.Timestamptz(6)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?         @map("deleted_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tipPool  TipPool  @relation(fields: [tipPoolId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  mlModel  MLModel? @relation(fields: [mlModelId], references: [id], onDelete: SetNull)
  adjuster User?    @relation("TipDistributionAdjustedBy", fields: [adjustedBy], references: [id], onDelete: SetNull)

  @@unique([tipPoolId, employeeId], name: "unique_distribution_per_employee_per_pool")
  @@index([tenantId])
  @@index([tenantId, tipPoolId])
  @@index([tenantId, employeeId])
  @@index([tenantId, deletedAt])
  @@index([tipPoolId])
  @@index([employeeId])
  @@index([employeeId, createdAt])
  @@index([mlModelId])
  @@map("tip_distributions")
}

/// One config per tenant. Defines the distribution rules.
model DistributionConfig {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String           @unique @map("tenant_id") @db.Uuid
  mode                 DistributionMode @default(RULES_ONLY)
  roleCoefficients     Json             @map("role_coefficients")
  minPerHour           Decimal          @default(2.00) @map("min_per_hour") @db.Decimal(10, 2)
  maxSharePct          Decimal          @default(35.00) @map("max_share_pct") @db.Decimal(5, 2)
  salesBonusWeight     Decimal          @default(0.5) @map("sales_bonus_weight") @db.Decimal(5, 4)
  tenureBonusEnabled   Boolean          @default(true) @map("tenure_bonus_enabled")
  fairnessAuditEnabled Boolean          @default(true) @map("fairness_audit_enabled")
  coldStartThreshold   Int              @default(30) @map("cold_start_threshold")
  updatedBy            String           @map("updated_by") @db.Uuid
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  updater User   @relation("DistributionConfigUpdatedBy", fields: [updatedBy], references: [id], onDelete: Restrict)

  @@map("distribution_configs")
}

// ============================================================================
// MACHINE LEARNING
// ============================================================================

/// One model per tenant.
/// Actual model bytes live in object storage; this table stores metadata.
model MLModel {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String        @map("tenant_id") @db.Uuid
  version              String        @db.VarChar(50)
  storageUrl           String        @map("storage_url") @db.VarChar(500)
  storageSizeBytes     BigInt?       @map("storage_size_bytes")
  algorithm            MLAlgorithm
  featureSchema        Json          @map("feature_schema")
  hyperparameters      Json?
  trainingSamplesCount Int           @default(0) @map("training_samples_count")
  metrics              Json?
  driftScore           Decimal?      @map("drift_score") @db.Decimal(5, 4)
  status               MLModelStatus @default(TRAINING)
  activatedAt          DateTime?     @map("activated_at") @db.Timestamptz(6)
  archivedAt           DateTime?     @map("archived_at") @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tipDistributions TipDistribution[]
  trainingEvents   MLTrainingEvent[]
  predictions      MLPrediction[]
  fairnessAudits   FairnessAudit[]

  @@unique([tenantId, version], name: "unique_version_per_tenant")
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("ml_models")
}

model MLTrainingEvent {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mlModelId        String          @map("ml_model_id") @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  shiftId          String          @map("shift_id") @db.Uuid
  features         Json
  targetValue      Decimal         @map("target_value") @db.Decimal(10, 4)
  predictionBefore Decimal?        @map("prediction_before") @db.Decimal(10, 4)
  loss             Decimal?        @db.Decimal(10, 6)
  triggeredBy      TrainingTrigger @map("triggered_by")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  mlModel MLModel @relation(fields: [mlModelId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shift   Shift   @relation(fields: [shiftId], references: [id], onDelete: Restrict)

  @@index([mlModelId])
  @@index([tenantId])
  @@index([tenantId, shiftId])
  @@index([mlModelId, createdAt])
  @@map("ml_training_events")
}

model MLPrediction {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mlModelId          String   @map("ml_model_id") @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  shiftId            String   @map("shift_id") @db.Uuid
  employeeId         String   @map("employee_id") @db.Uuid
  features           Json
  predictedScore     Decimal  @map("predicted_score") @db.Decimal(10, 4)
  confidenceInterval Json?    @map("confidence_interval")
  latencyMs          Int?     @map("latency_ms")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  mlModel  MLModel  @relation(fields: [mlModelId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([mlModelId])
  @@index([tenantId, shiftId])
  @@index([tenantId, employeeId])
  @@index([employeeId])
  @@map("ml_predictions")
}

/// Periodic fairness audits.
/// MVP recommendation: audit non-sensitive operational axes first:
/// role, tenure, shift_type, hours_worked, coefficient, sales volume.
model FairnessAudit {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mlModelId              String    @map("ml_model_id") @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  auditDate              DateTime  @map("audit_date") @db.Date
  demographicParityScore Decimal?  @map("demographic_parity_score") @db.Decimal(5, 4)
  equalOpportunityScore  Decimal?  @map("equal_opportunity_score") @db.Decimal(5, 4)
  flaggedPatterns        Json?     @map("flagged_patterns")
  recommendations        String?   @db.Text
  reviewedBy             String?   @map("reviewed_by") @db.Uuid
  reviewedAt             DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  mlModel  MLModel @relation(fields: [mlModelId], references: [id], onDelete: Cascade)
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  reviewer User?   @relation("FairnessAuditReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([mlModelId])
  @@index([tenantId, auditDate])
  @@map("fairness_audits")
}

// ============================================================================
// AUDIT & COMPLIANCE
// ============================================================================

/// Immutable audit trail. NEVER DELETE.
/// Use onDelete: Restrict to avoid contradiction with legal retention.
model AuditLog {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(100)
  entityId   String      @map("entity_id") @db.Uuid
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.Inet
  userAgent  String?     @map("user_agent") @db.Text
  requestId  String?     @map("request_id") @db.VarChar(100)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model PayrollExport {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  periodStart   DateTime     @map("period_start") @db.Date
  periodEnd     DateTime     @map("period_end") @db.Date
  format        ExportFormat
  storageUrl    String       @map("storage_url") @db.VarChar(500)
  generatedBy   String       @map("generated_by") @db.Uuid
  downloadedAt  DateTime?    @map("downloaded_at") @db.Timestamptz(6)
  signatureHash String       @map("signature_hash") @db.VarChar(64)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  generator User   @relation("PayrollExportGeneratedBy", fields: [generatedBy], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, periodStart, periodEnd])
  @@map("payroll_exports")
}

// ============================================================================
// BILLING
// ============================================================================

model Subscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String             @unique @map("tenant_id") @db.Uuid
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id") @db.VarChar(255)
  plan                 Plan
  status               SubscriptionStatus
  currentPeriodStart   DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime           @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@map("subscriptions")
}

model UsageMetric {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String          @map("tenant_id") @db.Uuid
  metricType  UsageMetricType @map("metric_type")
  value       Int
  periodMonth DateTime        @map("period_month") @db.Date
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, metricType, periodMonth], name: "unique_metric_per_period")
  @@index([tenantId])
  @@map("usage_metrics")
}

// ============================================================================
// IMPORTANT INTEGRITY NOTE
// ============================================================================
// Because tenant_id is intentionally denormalized on child tables, enforce tenant
// consistency in application services and/or PostgreSQL triggers.
// Example rule:
//   - OrderItem.tenant_id must equal Order.tenant_id.
//   - TipDistribution.tenant_id must equal TipPool.tenant_id and Employee.tenant_id.
//   - ShiftAssignment.tenant_id must equal Shift.tenant_id and Employee.tenant_id.
// Prisma cannot express cross-table CHECK constraints directly.
// ============================================================================
